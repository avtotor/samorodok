# Скопируй в .env и подставь значения.
# Пустая строка у ключа = взять встроенное значение по умолчанию (см. комментарии).

# --- HTTP ---
PORT=3000
# Лимит тела JSON (запрос /api/data): как в express, например 2mb, 512kb
JSON_BODY_LIMIT=2mb

# --- Пути (относительно папки resume-checker, если не абсолютные) ---
RESUMES_DIR=./resumes
VACANCIES_DIR=./vacancies
# Файл вакансии по умолчанию, если в запросе нет vacancyId и текста
VACANCY_FILE=
# Куда писать историю оценок (имя файла или абсолютный путь)
RESULTS_FILE=results.json

# --- Ollama ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma2 # qwen3:1.7b
# Контекст (токены): больше num_ctx → больше RAM. При «model requires more system memory…» уменьши (4096, 2048).
# 0 = не передавать num_ctx в API (дефолт Ollama для модели).
# Тяжёлые модели (mistral 7B и т.п.) на ПК с ~4–5 ГБ ОЗУ могут не влезть — тогда смени модель, например:
#   ollama pull qwen2.5:1.5b
#   OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_NUM_CTX=4096

# --- Лимиты текста в промпте (символы). 0 = без обрезки ---
RESUME_TEXT_MAX_CHARS=12000
VACANCY_TEXT_MAX_CHARS=8000

# --- Батч PDF за один запуск (верхняя граница для поля take из формы) ---
BATCH_TAKE_MAX=500

# --- Live reload в браузере (мс дебаунса при изменении public / vacancies) ---
LIVERELOAD_DEBOUNCE_MS=300
